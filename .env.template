# ============================================================
# Kalshi Weather Bot — Environment Variable Template
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#   nano .env
# ============================================================

# ---- Bot Mode -----------------------------------------------
# Set to "false" to enable live trading. "true" = simulation only.
DRY_RUN=true

# ---- Kalshi API ---------------------------------------------
# Your Kalshi API key UUID (from the Kalshi developer portal)
KALSHI_ACCESS_KEY=your-kalshi-api-key-uuid-here

# Your RSA private key in PEM format.
# Newlines must be represented as \n (the literal two characters backslash-n).
# Example:
#   KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----
KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END RSA PRIVATE KEY-----

# Kalshi API base URL (leave as-is unless Kalshi changes it)
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# ---- Telegram -----------------------------------------------
# Default values are pre-filled. Override if needed.
TELEGRAM_BOT_TOKEN=8701485015:AAH_GUm0x7s4gZIH3tRx1ahFKCpPmfN_2xw
TELEGRAM_CHAT_ID=8718921224

# ---- NOAA ---------------------------------------------------
# NWS requires a descriptive User-Agent. Replace with your info.
NOAA_USER_AGENT=KalshiWeatherBot/1.0 (your-email@example.com)

# ---- Trading Parameters -------------------------------------
# These have safe defaults. Override to tune strategy.
BUY_CONFIDENCE_THRESHOLD=0.85    # NOAA confidence required to buy (0.0-1.0)
BUY_MAX_PRICE=0.15               # Maximum YES ask price to buy at (dollars)
SELL_MIN_PRICE=0.45              # Minimum YES bid price to exit at (dollars)

# ---- Risk Limits --------------------------------------------
MAX_POSITION_USD=2.00            # Max dollars spent per position
MAX_OPEN_POSITIONS=5             # Max concurrent open positions
MAX_DAILY_LOSS_USD=50.00         # Kill switch: halt trading if daily loss exceeds this

# ---- Scan Settings ------------------------------------------
SCAN_INTERVAL_SECONDS=120        # How often to run a full scan (seconds)

# ---- Logging ------------------------------------------------
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
LOG_FILE=kalshi_weather_bot.log  # Log file path (leave blank to disable file logging)
